generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, vector]
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  username             String                 @unique
  passwordHash         String
  fullName             String?
  avatarUrl            String?
  phoneNumber          String?
  phoneVerified        Boolean                @default(false)
  emailVerified        Boolean                @default(false)
  trustScore           Int                    @default(50)
  trustLevel           TrustLevel             @default(NEWCOMER)
  badgeLevel           BadgeLevel             @default(NONE)
  totalReviews         Int                    @default(0)
  helpfulVotes         Int                    @default(0)
  verifiedReviews      Int                    @default(0)
  profileViews         Int                    @default(0)
  followersCount       Int                    @default(0)
  followingCount       Int                    @default(0)
  isActive             Boolean                @default(true)
  isBanned             Boolean                @default(false)
  banReason            String?
  lastLoginAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  dataRetentionPolicy  String?
  consentGivenAt       DateTime?
  lastConsentUpdateAt  DateTime?
  isAnonymized         Boolean                @default(false)
  bio                  String?
  businesses           Business[]
  businessClaimHistory BusinessClaimHistory[]
  muhtarApplications   MuhtarApplication[]
  notifications        Notification[]
  reportsReceived      Report[]               @relation("Reported")
  reportsMade          Report[]               @relation("Reporter")
  reviews              Review[]
  reviewVotes          ReviewVote[]
  savedBusinesses      SavedBusiness[]
  marketPurchases  MarketPurchase[]
  currentPoints    Int      @default(0)
  totalEarnedPoints Int     @default(0)
  pointLogs         MarketPointLog[]
  userEmbedding    UserEmbedding?
  userPreferences  UserPreference[]
  trustScoreHistory    TrustScoreHistory[]
  userFollowing        UserFollow[]           @relation("Followers")
  userFollowers        UserFollow[]           @relation("Following")

  @@index([email])
  @@index([username])
  @@index([trustScore])
  @@index([badgeLevel])
  @@index([createdAt])
}

model TrustScoreHistory {
  id        String   @id @default(cuid())
  userId    String
  oldScore  Int
  newScore  Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Business {
  id                   String                 @id @default(cuid())
  name                 String
  slug                 String                 @unique
  description          String?
  address              String
  city                 String
  district             String?
  postalCode           String?
  latitude             Float?
  longitude            Float?
  phoneNumber          String?
  email                String?
  website              String?
  googlePlaceId        String?                @unique
  categoryId           String
  attributes           Json                   @default("{}")
  averageRating        Float                  @default(0)
  totalReviews         Int                    @default(0)
  totalViews           Int                    @default(0)
  claimStatus          ClaimStatus            @default(UNCLAIMED)
  isVerified           Boolean                @default(false)
  verifiedAt           DateTime?
  ownerId              String?
  isActive             Boolean                @default(true)
  isDeleted            Boolean                @default(false)
  verifiedBusiness     Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  subscriptionPlan     String                 @default("FREE")
  subscriptionEndsAt   DateTime?
  trustScore         Float    @default(0)
  trustGrade         String   @default("?")
  trustCalcAt        DateTime?
  recentTrend        Float    @default(0)
  percentileRank     Float    @default(0)
  isSuspicious       Boolean  @default(false)
  verificationLevel    Int                    @default(0)
  verifiedPhone        String?
  verifiedEmail        String?
  businessAttributes   Attribute[]
  autoServiceProfile   AutoServiceProfile?
  category             Category               @relation(fields: [categoryId], references: [id])
  owner                User?                  @relation(fields: [ownerId], references: [id])
  badges               BusinessBadge[]
  claimHistory         BusinessClaimHistory[]
  embedding            BusinessEmbedding?
  photos               BusinessPhoto[]
  qaEntries            BusinessQA[]
  subscriptions        BusinessSubscription[]
  externalReviews      ExternalReview[]
  openingHours         OpeningHours[]
  reviews              Review[]
  savedBy              SavedBusiness[]
  sources              Source[]
  UpgradeRequest       UpgradeRequest[]
  verificationRequests VerificationRequest[]

  @@index([slug])
  @@index([categoryId])
  @@index([city, district])
  @@index([averageRating])
  @@index([isActive, isDeleted])
  @@index([latitude, longitude])
  @@index([googlePlaceId])
}

model OpeningHours {
  id         String   @id @default(cuid())
  day        String
  openTime   String
  closeTime  String
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Attribute {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Source {
  id         String   @id @default(cuid())
  name       String
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BusinessClaimHistory {
  id         String      @id @default(cuid())
  businessId String
  userId     String
  status     ClaimStatus
  documents  Json        @default("[]")
  reviewedBy String?
  reviewedAt DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
  @@index([status, createdAt])
}

model Category {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  icon            String?
  parentId        String?
  attributeSchema Json               @default("[]")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  businesses      Business[]
  userPreferences  UserPreference[]
  parent          Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        Category[]         @relation("CategoryHierarchy")
  embedding       CategoryEmbedding?

  @@index([slug])
  @@index([parentId])
}

model Review {
  id                     String        @id @default(cuid())
  userId                 String
  businessId             String
  rating                 Int
  title                  String?
  content                String
  helpfulCount           Int           @default(0)
  notHelpfulCount        Int           @default(0)
  viewCount              Int           @default(0)
  isVerified             Boolean       @default(false)
  verifiedPurchase       Boolean       @default(false)
  isPublished            Boolean       @default(true)
  isFlagged              Boolean       @default(false)
  flagReason             String?
  fraudDetectionMetadata Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  ownerReply             String?
  ownerReplyDate         DateTime?     @db.Timestamp(6)
  sentiment              String?
  sentimentScore         Float?
  sentimentKeywords      String[]
  reports                Report[]
  business               Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos                 ReviewPhoto[]
  votes                  ReviewVote[]

  @@unique([userId, businessId])
  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([rating])
  @@index([isPublished, isFlagged])
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  isHelpful Boolean
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model BusinessPhoto {
  id         String   @id @default(cuid())
  businessId String
  url        String
  caption    String?
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model ExternalReview {
  id                String           @id @default(cuid())
  businessId        String
  source            ReviewSource
  sourceId          String?
  sourceUrl         String?
  authorName        String?
  authorPhoto       String?
  authorProfileUrl  String?
  authorReviewCount Int?
  authorLevel       String?
  rating            Float?
  content           String?
  photos            Json?            @default("[]")
  ownerReply        String?
  ownerReplyDate    DateTime?
  publishedAt       DateTime?
  scrapedAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  isVisible         Boolean          @default(true)
  language          String?          @default("tr")
  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  embedding         ReviewEmbedding?

  @@unique([source, sourceId])
  @@index([businessId, source])
  @@index([businessId, publishedAt(sort: Desc)])
  @@index([scrapedAt(sort: Desc)])
}

model ReviewEmbedding {
  id        String                @id @default(cuid())
  reviewId  String                @unique
  model     String
  embedding Unsupported("vector")
  createdAt DateTime              @default(now())
  review    ExternalReview        @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model BusinessEmbedding {
  id         String                @id @default(cuid())
  businessId String                @unique
  model      String
  embedding  Unsupported("vector")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  business   Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Report {
  id               String       @id @default(cuid())
  reporterId       String
  reportedUserId   String?
  reportedReviewId String?
  reason           ReportReason
  description      String?
  status           ReportStatus @default(PENDING)
  resolvedAt       DateTime?
  resolvedBy       String?
  resolution       String?
  createdAt        DateTime     @default(now())
  reportedReview   Review?      @relation(fields: [reportedReviewId], references: [id], onDelete: Cascade)
  reportedUser     User?        @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter         User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
}

model BusinessQA {
  id         String   @id @default(cuid())
  businessId String
  question   String
  answer     String
  category   String?
  confidence Float?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([category])
}

model CategoryEmbedding {
  id         String                 @id @default(cuid())
  categoryId String                 @unique
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())
  category   Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model SavedBusiness {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
}

model MuhtarApplication {
  id           String   @id @default(cuid())
  userId       String
  neighborhood String
  district     String
  city         String
  reason       String
  status       String   @default("PENDING")
  adminNote    String?
  reviewedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model BusinessBadge {
  id         String            @id @default(cuid())
  businessId String
  type       BusinessBadgeType
  awardedBy  String?
  awardedAt  DateTime          @default(now())
  expiresAt  DateTime?
  isActive   Boolean           @default(true)
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId])
  @@index([type])
}

model BusinessSubscription {
  id         String   @id @default(cuid())
  businessId String
  plan       String
  startsAt   DateTime @default(now())
  endsAt     DateTime
  price      Float
  currency   String   @default("TRY")
  status     String   @default("ACTIVE")
  createdBy  String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([status])
}

model AutoServiceProfile {
  id                     String    @id @default(cuid())
  businessId             String    @unique
  scoreTecrube           Float     @default(0)
  scoreFiyatSeffafligi   Float     @default(0)
  scoreTeknikYetkinlik   Float     @default(0)
  scoreMusteriIliskileri Float     @default(0)
  scoreEkipman           Float     @default(0)
  scoreGaranti           Float     @default(0)
  ustaSicili             Int?
  liftSayisi             Int?
  garantiSuresiAy        Int?
  sertifikalar           String[]  @default([])
  uzmanlikAlanlari       String[]  @default([])
  totalRatings           Int       @default(0)
  lastCalculatedAt       DateTime? @db.Timestamp(6)
  createdAt              DateTime  @default(now()) @db.Timestamp(6)
  updatedAt              DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  business               Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model VerificationRequest {
  id          String    @id @default(cuid())
  businessId  String
  type        String
  code        String?
  token       String?
  phone       String?
  email       String?
  status      String    @default("pending")
  attempts    Int       @default(0)
  expiresAt   DateTime? @db.Timestamp(6)
  documentUrl String?
  adminNote   String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now())
}

model UpgradeRequest {
  id         String   @id
  businessId String
  userId     String
  planWanted String
  phone      String?
  note       String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  Business   Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([status])
}

enum TrustLevel {
  NEWCOMER
  DEVELOPING
  TRUSTED
  HIGHLY_TRUSTED
  VERIFIED
}

enum BadgeLevel {
  NONE
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum NotificationType {
  NEW_FOLLOWER
  REVIEW_REPLY
  REVIEW_HELPFUL
  BADGE_EARNED
  TRUST_LEVEL_UP
  BUSINESS_CLAIMED
  CLAIM_APPROVED
  CLAIM_REJECTED
  OWNER_REPLY
  SYSTEM
  NEW_REVIEW
  REVIEW_LIKED
  BADGE_AWARDED
}

enum ClaimStatus {
  UNCLAIMED
  PENDING
  CLAIMED
  REJECTED
}

enum ReviewSource {
  GOOGLE
  SIKAYETVAR
  TRIPADVISOR
  FOURSQUARE
  YELP
  FACEBOOK
  OTHER
  YANDEX
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  FAKE_REVIEW
  HARASSMENT
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum BusinessBadgeType {
  VERIFIED
  NEIGHBORHOOD_FAVORITE
  FEATURED
  PREMIUM
  TOP_RATED
  HIGHLY_REVIEWED
  NEW_BUSINESS
  TRUSTED
  VERIFIED_GOOGLE
  VERIFIED_EMAIL
  VERIFIED_SMS
  VERIFIED_ADDRESS
  VERIFIED_PLATINUM
}

model MarketItem {
  id             String   @id @default(cuid())
  name           String
  description    String?
  pointCost      Int
  category       String   @default("BADGE")
  imageUrl       String?
  stock          Int      @default(-1)
  isActive       Boolean  @default(true)
  totalRedeemed  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  purchases      MarketPurchase[]
}

model MarketPurchase {
  id           String     @id @default(cuid())
  userId       String
  itemId       String
  pointsSpent  Int        @default(0)
  deliveryInfo Json?
  status       String     @default("COMPLETED")
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  item         MarketItem @relation(fields: [itemId], references: [id])
}


model MarketPointLog {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  reason      String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model UserEmbedding {
  id           String   @id @default(cuid())
  userId       String   @unique
  vector       Float[]
  reviewCount  Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model UserPreference {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  avgRating   Float    @default(0)
  reviewCount Int      @default(0)
  isBlocked   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
}
